function ClientCard({ client }) {
  return (
    <a
      href__={client.url}
      target="_blank"
      rel="noopener noreferrer"
      className="group flex flex-col gap-3 border-4 border-border bg-card p-5 shadow-[6px_6px_0_0_hsl(var(--border))] transition-transform duration-100 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[8px_8px_0_0_hsl(var(--border))] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0_0_hsl(var(--border))]">
      <div className="flex items-center justify-between gap-2">
        <span className="inline-block bg-accent px-2 py-1 font-display text-[10px] leading-none text-accent-foreground">
          {client.tag}
        </span>
        <ExternalLink className="h-5 w-5 text-muted-foreground transition-colors group-hover:text-primary" />
      </div>
      <h2 className="font-display text-sm leading-relaxed text-primary text-balance">
        {client.name}
      </h2>
      <p className="text-sm leading-relaxed text-muted-foreground">
        {client.description}
      </p>
      <span className="mt-2 inline-block self-start border-2 border-primary bg-primary px-3 py-2 font-display text-[10px] leading-none text-primary-foreground transition-colors group-hover:bg-card group-hover:text-primary">
        PLAY NOW
      </span>
    </a>
  );
}

